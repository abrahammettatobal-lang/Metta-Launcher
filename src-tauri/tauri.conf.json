{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Metta Launcher",
  "version": "0.7.2",
  "identifier": "com.metta.launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Metta Launcher",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "backgroundColor": "#080807"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "macOS": {
      "minimumSystemVersion": "11.0",
      "dmg": {
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 }
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU0RUQzNkQyMENGRjA1OUEKUldTYUJmOE0wamJ0NUJ0enA0dFJKTFRBbW9KYnpMRWY4ay9VQklBOUQxTHNEbXNUL0ZnQ05XdUoK",
      "endpoints": [
        "https://github.com/abrahammettatobal-lang/Metta-Launcher/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
